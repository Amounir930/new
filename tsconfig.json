{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "composite": false,
    "lib": ["ESNext", "DOM"],
    "types": ["node", "bun-types", "express"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@apex/auth": ["packages/auth/dist/index.d.ts"],
      "@apex/events": ["packages/events/dist/index.d.ts"],
      "@apex/ui": ["packages/ui/dist/index.d.ts"],
      "@apex/ui/*": ["packages/ui/dist/*"],
      "@apex/builder-ui": ["packages/builder-ui/dist/index.d.ts"],
      "@apex/template-engine": ["packages/template-engine/dist/index.d.ts"],
      "@apex/template-config": ["packages/template-config/dist/index.d.ts"],
      "@apex/export": ["packages/export/dist/index.d.ts"],
      "~/*": ["./*"]
    }
  },
  "exclude": ["node_modules", "dist", "build", ".turbo"]
}
