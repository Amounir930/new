{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "composite": false,
    "lib": ["ESNext", "DOM"],
    "types": ["node", "bun-types", "express"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["./*"],
      "@apex/config/client": ["./packages/config/src/client.ts"],
      "@apex/config/server": ["./packages/config/src/server.ts"],
      "@apex/config/service": ["./packages/config/src/config.service.ts"],
      "@apex/config": ["./packages/config/src/index.ts"],
      "@apex/*": ["./packages/*/src"]
    }
  },
  "exclude": ["node_modules", "dist", "build", ".turbo"]
}
