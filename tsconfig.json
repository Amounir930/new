{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "composite": true,
    "lib": [
      "ESNext",
      "DOM"
    ],
    "types": [
      "node",
      "bun-types",
      "express"
    ],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@apex/audit": [
        "packages/audit/dist/index.d.ts"
      ],
      "@apex/db": [
        "packages/db/dist/index.d.ts"
      ],
      "@apex/config": [
        "packages/config/dist/index.d.ts"
      ],
      "@apex/provisioning": [
        "packages/provisioning/dist/index.d.ts"
      ],
      "@apex/middleware": [
        "packages/middleware/dist/index.d.ts"
      ],
      "@apex/events": [
        "packages/events/dist/index.d.ts"
      ],
      "@apex/ui": [
        "packages/ui/dist/index.d.ts"
      ],
      "@apex/security": [
        "packages/security/dist/index.d.ts"
      ],
      "@apex/auth": [
        "packages/auth/dist/index.d.ts"
      ],
      "@apex/template-config": [
        "packages/template-config/dist/index.d.ts"
      ],
      "@apex/template-validator": [
        "packages/template-validator/dist/index.d.ts"
      ],
      "@apex/template-loader": [
        "packages/template-loader/dist/index.d.ts"
      ],
      "@apex/template-security": [
        "packages/template-security/dist/index.d.ts"
      ],
      "@apex/test-utils": [
        "packages/test-utils/dist/index.d.ts"
      ]
    }
  },
  "files": [],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".turbo",
    "**/*.d.ts"
  ],
  "references": [
    {
      "path": "./packages/config"
    },
    {
      "path": "./packages/audit"
    },
    {
      "path": "./packages/db"
    },
    {
      "path": "./packages/middleware"
    },
    {
      "path": "./packages/provisioning"
    },
    {
      "path": "./packages/auth"
    },
    {
      "path": "./apps/api"
    },
    {
      "path": "./apps/web"
    },
    {
      "path": "./packages/events"
    },
    {
      "path": "./packages/ui"
    },
    {
      "path": "./packages/security"
    }
  ]
}