{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "composite": true,
    "lib": [
      "ESNext",
      "DOM"
    ],
    "types": [
      "node",
      "bun-types",
      "express"
    ],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": "."
  },
  "files": [],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".turbo",
    "**/*.d.ts"
  ],
  "references": [
    {
      "path": "./packages/config"
    },
    {
      "path": "./packages/audit"
    },
    {
      "path": "./packages/db"
    },
    {
      "path": "./packages/middleware"
    },
    {
      "path": "./packages/provisioning"
    },
    {
      "path": "./packages/auth"
    },
    {
      "path": "./apps/api"
    },
    {
      "path": "./apps/web"
    },
    {
      "path": "./packages/events"
    },
    {
      "path": "./packages/ui"
    },
    {
      "path": "./packages/security"
    }
  ]
}