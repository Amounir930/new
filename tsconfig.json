{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "composite": false,
    "lib": [
      "ESNext",
      "DOM"
    ],
    "types": [
      "node",
      "bun-types",
      "express"
    ],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@apex/config": [
        "packages/config/dist/index.d.ts"
      ],
      "@apex/audit": [
        "packages/audit/dist/index.d.ts"
      ],
      "@apex/db": [
        "packages/db/dist/index.d.ts"
      ],
      "@apex/middleware": [
        "packages/middleware/dist/index.d.ts"
      ],
      "@apex/provisioning": [
        "packages/provisioning/dist/index.d.ts"
      ],
      "@apex/auth": [
        "packages/auth/dist/index.d.ts"
      ],
      "@apex/events": [
        "packages/events/dist/index.d.ts"
      ],
      "@apex/security": [
        "packages/security/dist/index.d.ts"
      ],
      "@apex/test-utils": [
        "packages/test-utils/dist/index.d.ts"
      ],
      "@apex/ui": [
        "packages/ui/dist/index.d.ts"
      ],
      "@apex/ui/*": [
        "packages/ui/dist/*"
      ],
      "@apex/builder-ui": [
        "packages/builder-ui/dist/index.d.ts"
      ],
      "@apex/template-engine": [
        "packages/template-engine/dist/index.d.ts"
      ],
      "@apex/validators": [
        "packages/validators/dist/index.d.ts"
      ],
      "@apex/template-config": [
        "packages/template-config/dist/index.d.ts"
      ],
      "@apex/export": [
        "packages/export/dist/index.d.ts"
      ],
      "~/*": [
        "./*"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".turbo"
  ]
}