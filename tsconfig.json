{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "composite": false,
    "lib": ["ESNext", "DOM"],
    "types": ["node", "bun-types", "express"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["./*"],
      "@apex/provisioning/client": ["./packages/provisioning/src/client.ts"],
      "@apex/*": ["./packages/*/src"]
    }
  },
  "exclude": ["node_modules", "dist", "build", ".turbo"]
}
