    "@apex/monitoring": "workspace:*",
    "@apex/provisioning": "workspace:*",
    "@apex/validation": "workspace:*",
    "@aws-sdk/client-s3": "^3.1012.0",
    "@aws-sdk/s3-request-presigner": "^3.1012.0",
    "@nestjs/bull": "^11.0.4",
