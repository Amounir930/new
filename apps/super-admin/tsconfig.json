{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "baseUrl": ".",
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@apex/config/client": ["../../packages/config/src/client.ts"],
      "@apex/config/server": ["../../packages/config/src/server.ts"],
      "@apex/config/service": ["../../packages/config/src/config.service.ts"],
      "@apex/config": ["../../packages/config/src/index.ts"],
      "@apex/provisioning/client": ["../../packages/provisioning/src/client.ts"],
      "@apex/*": ["../../packages/*/src"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
