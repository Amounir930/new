# APEX Production Environment Template 🛡️
# Copy this file to .env and fill in the values.
# DO NOT COMMIT THE ACTUAL .env FILE!

# ═══════════════════════════════════════════════════════════════
# S1: Database Configuration
# ═══════════════════════════════════════════════════════════════
POSTGRES_USER=apex
POSTGRES_PASSWORD=CHANGE_ME_IMMEDIATELY
POSTGRES_DB=apex_v2
DATABASE_URL=postgresql://apex:CHANGE_ME_IMMEDIATELY@postgres:5432/apex_v2

# ═══════════════════════════════════════════════════════════════
# S6: Cache Layer
# ═══════════════════════════════════════════════════════════════
REDIS_PASSWORD=CHANGE_ME_IMMEDIATELY
REDIS_URL=redis://:CHANGE_ME_IMMEDIATELY@redis:6379

# ═══════════════════════════════════════════════════════════════
# S3: Object Storage
# ═══════════════════════════════════════════════════════════════
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_IMMEDIATELY
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_IMMEDIATELY

# ═══════════════════════════════════════════════════════════════
# S7: Security & Encryption
# ═══════════════════════════════════════════════════════════════
JWT_SECRET=GENERATE_32_CHAR_STRING
ENCRYPTION_MASTER_KEY=GENERATE_32_CHAR_STRING
SUPER_ADMIN_EMAIL=admin@60sec.shop
SUPER_ADMIN_PASSWORD=CHANGE_ME_IMMEDIATELY

# ═══════════════════════════════════════════════════════════════
# S15: External Services
# ═══════════════════════════════════════════════════════════════
GITEA_DB_PASSWORD=CHANGE_ME_IMMEDIATELY
WEBHOOK_SECRET=CHANGE_ME_IMMEDIATELY
ACME_EMAIL=admin@60sec.shop

# ═══════════════════════════════════════════════════════════════
# Third Party APIs
# ═══════════════════════════════════════════════════════════════
HCAPTCHA_SITE_KEY=your_site_key
HCAPTCHA_SECRET_KEY=your_secret_key
GLITCHTIP_DSN=your_dsn
