# ═══════════════════════════════════════════════════════════════
# 🔐 APEX v2 PRODUCTION CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# Service: Database
POSTGRES_USER=apex_prod
POSTGRES_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD_64_CHAR
POSTGRES_DB=apex_prod

# Service: Redis
REDIS_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD_64_CHAR

# Service: MinIO (S3)
MINIO_ROOT_USER=apex_minio_admin
MINIO_ROOT_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD_64_CHAR

# Service: API
# Generate new keys using `openssl rand -hex 32`
JWT_SECRET=CHANGE_THIS_TO_SECURE_SECRET_AT_LEAST_32_CHARS_LONG
ENCRYPTION_MASTER_KEY=CHANGE_THIS_TO_SECURE_KEY_WITH_UPPER_LOWER_NUM_SPECIAL

# Service: Traefik (SSL)
ACME_EMAIL=admin@your-domain.com

# Service: Sentry (Optional)
NEXT_PUBLIC_SENTRY_DSN=

# Domain Configuration
DOMAIN_NAME=your-domain.com
API_DOMAIN=api.your-domain.com
STOREFRONT_DOMAIN=store.your-domain.com
