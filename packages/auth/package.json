{
  "name": "@apex/auth",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --outDir ./dist --declaration --declarationMap --sourceMap && echo 'Build completed'",
    "test": "cross-env NODE_ENV=test bun test",
    "test:coverage": "cross-env NODE_ENV=test bun test --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "bun x tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "11.1.16",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "@apex/config": "workspace:*",
    "@apex/db": "workspace:*",
    "@apex/middleware": "workspace:*",
    "@apex/security": "workspace:*",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6",
    "bcrypt": "^6.0.0"
  },
  "devDependencies": {
    "@apex/test-utils": "workspace:*",
    "@nestjs/testing": "^11.1.16",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/passport-jwt": "^4.0.1",
    "bun-types": "latest",
    "typescript": "^5.3.0"
  }
}
