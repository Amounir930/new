{
  "name": "@apex/test-utils",
  "version": "1.0.0",
  "description": "Testing utilities for Apex v2 templates",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "echo 'Build skipped'",
    "dev": "tsup --watch",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "bun x tsc --noEmit"
  },
  "keywords": [
    "testing",
    "mocks",
    "fixtures",
    "test-utils"
  ],
  "dependencies": {
    "@faker-js/faker": "^8.3.1",
    "@nestjs/common": "10.4.16",
    "@nestjs/testing": "10.4.16",
    "msw": "^2.0.11",
    "reflect-metadata": "^0.2.1",
    "ts-morph": "^21.0.1"
  },
  "devDependencies": {
    "@apex/validators": "workspace:*",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "bun-types": "latest"
  }
}
