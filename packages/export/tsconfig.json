{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "paths": {
      "@apex/db": [
        "../db/dist"
      ],
      "@apex/config": [
        "../config/dist"
      ],
      "@apex/audit": [
        "../audit/dist"
      ],
      "@apex/security": [
        "../security/dist"
      ]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "**/*.test.ts"
  ]
}