{
  "name": "@apex/export",
  "version": "1.0.0",
  "description": "Tenant Data Export System - S2 Compliant with BullMQ",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --outDir ./dist --declaration --declarationMap --sourceMap && echo 'Build completed'",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "bun x tsc --noEmit"
  },
  "dependencies": {
    "@apex/audit": "workspace:*",
    "@apex/config": "workspace:*",
    "@apex/db": "workspace:*",
    "@aws-sdk/client-s3": "^3.450.0",
    "@aws-sdk/s3-request-presigner": "^3.450.0",
    "@nestjs/common": "11.1.17",
    "bullmq": "^5.0.0",
    "nestjs-zod": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@apex/test-utils": "workspace:*",
    "@nestjs/config": "^4.0.3",
    "@nestjs/testing": "11.1.17",
    "bun-types": "latest",
    "typescript": "^6.0.2"
  }
}
