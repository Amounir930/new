{
  "name": "@apex/export",
  "version": "1.0.0",
  "description": "Tenant Data Export System - S2 Compliant with BullMQ",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --outDir ./dist --declaration --declarationMap --sourceMap && echo 'Build completed'",
    "test": "vitest run",
    "test:coverage": "vitest run",
    "lint": "biome check --apply .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@apex/audit": "workspace:*",
    "@apex/db": "workspace:*",
    "@aws-sdk/client-s3": "^3.450.0",
    "@aws-sdk/s3-request-presigner": "^3.450.0",
    "@nestjs/common": "^10.0.0",
    "bullmq": "^5.0.0"
  },
  "devDependencies": {
    "@apex/test-utils": "workspace:*",
    "@nestjs/config": "^3.1.1",
    "@nestjs/testing": "^10.0.0",
    "@vitest/coverage-istanbul": "1.6.1",
    "bun-types": "latest",
    "typescript": "^5.3.0",
    "vitest": "1.6.1",
    "vite-tsconfig-paths": "^4.3.1"
  }
}