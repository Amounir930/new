{
  "name": "@apex/middleware",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --outDir ./dist --declaration --declarationMap --sourceMap && echo 'Build completed'",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "bun x tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@apex/config": "workspace:*",
    "@apex/db": "workspace:*",
    "@sentry/nestjs": "10.47.0",
    "express": "5.2.1",
    "redis": "5.11.0",
    "rxjs": "7.8.2",
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0"
  },
  "devDependencies": {
    "@apex/test-utils": "workspace:*",
    "@nestjs/common": "11.1.17",
    "@nestjs/core": "11.1.17",
    "@types/node": "^25.5.0",
    "bun-types": "latest",
    "@types/express": "^5.0.6",
    "typescript": "^6.0.2"
  }
}
