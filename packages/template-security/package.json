{
  "name": "@apex/template-security",
  "version": "1.0.0",
  "description": "Security validation and penetration testing for Apex v2 templates",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --outDir ./dist --declaration --declarationMap --sourceMap && echo 'Build completed'",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "validate:s1": "bun ../../tools/security-scripts/verify-env-config.ts",
    "scan:patterns": "bun src/scanners/pattern-scanner.ts",
    "report:orchestrate": "bun src/utils/report-orchestrator.ts",
    "security:score:calculate": "bun src/utils/score-calculator.ts"
  },
  "keywords": [
    "security",
    "validation",
    "penetration-testing",
    "template"
  ],
  "dependencies": {
    "zod": "^3.22.4",
    "glob": "^10.3.10",
    "fast-glob": "^3.3.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "cross-env": "^10.1.0",
    "typescript": "^5.3.3"
  }
}