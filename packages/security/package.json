{
  "name": "@apex/security",
  "version": "1.0.0",
  "description": "Advanced security modules for KIMI - mTLS, secrets rotation, penetration testing",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./mtls": {
      "import": "./dist/mtls/index.js",
      "types": "./dist/mtls/index.d.ts"
    },
    "./secrets": {
      "import": "./dist/secrets/index.js",
      "types": "./dist/secrets/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --outDir ./dist --declaration --declarationMap --sourceMap && echo 'Build completed'",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --apply .",
    "typecheck": "tsc --noEmit",
    "security-scan": "bun run src/utils/scanner-cli.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-morph": "^27.0.2",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "keywords": [
    "security",
    "mtls",
    "secrets-rotation",
    "penetration-testing"
  ],
  "license": "MIT"
}