{
  "name": "@apex/security",
  "version": "1.0.0",
  "description": "Advanced security modules for KIMI - mTLS, secrets rotation, penetration testing",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./mtls": {
      "types": "./dist/mtls/index.d.ts",
      "import": "./dist/mtls/index.js",
      "require": "./dist/mtls/index.js"
    },
    "./secrets": {
      "types": "./dist/secrets/index.d.ts",
      "import": "./dist/secrets/index.js",
      "require": "./dist/secrets/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --outDir ./dist --declaration --declarationMap --sourceMap && echo 'Build completed'",
    "test": "bun test --timeout 15000",
    "test:coverage": "bun test --coverage --timeout 15000",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "bun x tsc --noEmit",
    "security-scan": "bun run src/utils/scanner-cli.ts",
    "sentinel": "bun run src/utils/ci-sentinel.ts"
  },
  "dependencies": {
    "@apex/config": "workspace:*",
    "dotenv": "^16.4.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@nestjs/common": "10.4.16",
    "@nestjs/core": "10.4.16",
    "@types/node": "^20.0.0",
    "bun-types": "latest",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "security",
    "mtls",
    "secrets-rotation",
    "penetration-testing"
  ],
  "license": "MIT"
}
