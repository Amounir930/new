{
  "name": "@apex/provisioning",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "bun x tsc -p tsconfig.json --outDir ./dist --declaration --declarationMap --sourceMap && echo 'Build completed'",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "bun x tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@apex/config": "workspace:*",
    "@apex/db": "workspace:*",
    "@apex/security": "workspace:*",
    "minio": "^7.1.0",
    "pg": "^8.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "bun-types": "latest",
    "typescript": "^5.3.0"
  }
}
