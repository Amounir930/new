{
    "name": "@apex/builder-ui",
    "version": "1.0.0",
    "description": "Visual Store Builder UI for Apex v2",
    "type": "module",
    "main": "./dist/index.cjs",
    "types": "./dist/index.d.ts",
    "module": "./dist/index.js",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts --external react,react-dom,@apex/ui,@apex/template-engine --tsconfig ./tsconfig.json",
        "dev": "tsup src/index.ts --format cjs,esm --dts --watch --external react,@apex/ui,@apex/template-engine --tsconfig ./tsconfig.json",
        "test": "bun test",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@apex/ui": "workspace:*",
        "@apex/template-engine": "workspace:*",
        "react": "^18.0.0",
        "react-dom": "^18.0.0",
        "zustand": "^4.5.0",
        "clsx": "^2.1.0",
        "tailwind-merge": "^2.2.1",
        "lucide-react": "^0.344.0"
    },
    "devDependencies": {
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "@types/node": "^20.0.0",
        "bun-types": "latest",
        "tsup": "^8.0.1",
        "typescript": "^5.3.3"
    }
}