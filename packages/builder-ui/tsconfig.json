{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "composite": false,
        "outDir": "./dist",
        "rootDir": "./src",
        "jsx": "react-jsx",
        "declaration": true,
        "declarationMap": true
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "**/*.test.ts",
        "**/*.test.tsx"
    ]
}