{
    "name": "@apex/template-engine",
    "version": "1.0.0",
    "description": "Template composition engine for Apex v2 - Combines UI components into complete page templates",
    "type": "module",
    "main": "./dist/index.cjs",
    "types": "./dist/index.d.ts",
    "module": "./dist/index.js",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts --external react,react-dom --tsconfig ./tsconfig.json",
        "dev": "tsup src/index.ts --format cjs,esm --dts --watch --external react --tsconfig ./tsconfig.json",
        "test": "bun test",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@apex/ui": "workspace:*",
        "react": "^18.0.0",
        "react-dom": "^18.0.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "@types/node": "^20.0.0",
        "bun-types": "latest",
        "tsup": "^8.0.1",
        "typescript": "^5.3.3"
    }
}