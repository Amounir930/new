{
  "name": "@apex/db",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 tsc -p tsconfig.json --outDir ./dist --declaration --declarationMap --sourceMap && echo 'Build completed'",
    "db:generate": "drizzle-kit generate:pg",
    "db:push": "drizzle-kit push:pg",
    "db:migrate": "bun src/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "test": "cross-env NODE_ENV=test vitest run",
    "test:s2": "cross-env NODE_ENV=test vitest run src/s2-isolation.test.ts",
    "test:s7": "cross-env NODE_ENV=test vitest run src/s7-encryption.test.ts",
    "test:coverage": "cross-env NODE_ENV=test vitest run --coverage",
    "lint": "biome check --apply .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@apex/config": "workspace:*",
    "@apex/security": "workspace:*",
    "@nestjs/common": "^10.0.0",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.10.0",
    "bun-types": "latest",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.30.4",
    "typescript": "^5.3.0",
    "vite-tsconfig-paths": "^6.1.0",
    "vitest": "1.6.1"
  }
}