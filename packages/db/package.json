{
  "name": "@apex/db",
  "version": "1.0.0",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "import": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "imports": {
    "#/*": "./src/*.ts"
  },
  "scripts": {
    "build": "bun x tsc -p tsconfig.json --outDir ./dist --declaration --declarationMap --sourceMap && echo 'Build completed'",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push:pg",
    "db:migrate": "bun src/run-migrate.ts",
    "db:studio": "drizzle-kit studio",
    "test": "cross-env NODE_ENV=test bun test",
    "test:s2": "cross-env NODE_ENV=test bun test src/s2-isolation.test.ts",
    "test:s7": "cross-env NODE_ENV=test bun test src/s7-encryption.test.ts",
    "test:coverage": "cross-env NODE_ENV=test bun test --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "bun x tsc --noEmit"
  },
  "dependencies": {
    "@apex/config": "workspace:*",
    "@apex/security": "workspace:*",
    "@apex/validators": "workspace:*",
    "@nestjs/common": "11.1.16",
    "drizzle-orm": "0.45.1",
    "pg": "8.20.0",
    "zod": "^4.3.6",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@swc/core": "^1.15.13",
    "@types/bun": "latest",
    "@types/node": "^25.5.0",
    "@types/pg": "8.18.0",
    "bun-types": "latest",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.3.3",
    "vite-tsconfig-paths": "^6.1.0"
  }
}
