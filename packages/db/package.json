{
  "name": "@apex/db",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 tsc -p tsconfig.json --outDir ./dist --declaration --declarationMap --sourceMap && echo 'Build completed'",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push:pg",
    "db:migrate": "bun src/run-migrate.ts",
    "db:studio": "drizzle-kit studio",
    "test": "cross-env NODE_ENV=test bun test",
    "test:s2": "cross-env NODE_ENV=test bun test src/s2-isolation.test.ts",
    "test:s7": "cross-env NODE_ENV=test bun test src/s7-encryption.test.ts",
    "test:coverage": "cross-env NODE_ENV=test bun test --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@apex/config": "workspace:*",
    "@apex/security": "workspace:*",
    "@apex/validators": "workspace:*",
    "@nestjs/common": "10.4.16",
    "drizzle-orm": "0.45.1",
    "pg": "8.11.0",
    "zod": "^3.22.4",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@swc/core": "^1.15.13",
    "@types/bun": "latest",
    "@types/node": "^20.0.0",
    "@types/pg": "8.11.0",
    "bun-types": "latest",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.30.4",
    "typescript": "^5.3.3",
    "vite-tsconfig-paths": "^6.1.0"
  }
}