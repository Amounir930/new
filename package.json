{
  "name": "apex-v2",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "ci": "biome ci .",
    "test": "turbo run test --parallel",
    "test:coverage": "turbo run test:coverage --parallel -- --coverage-reporter=lcov",
    "test:prod": "cross-env NODE_ENV=production turbo run test --parallel",
    "typecheck": "turbo run typecheck",
    "audit": "bun audit",
    "cli": "cd apps/api && bun run cli",
    "db:push": "echo 'No migrations to push'",
    "postinstall": "echo 'Run: bun install'",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@rollup/rollup-win32-x64-msvc": "^4.57.1",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.33",
    "@types/supertest": "^6.0.3",
    "bun-types": "latest",
    "cross-env": "^10.1.0",
    "dependency-cruiser": "^17.3.8",
    "express": "^4.22.1",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "supertest": "^7.2.2",
    "ts-morph": "^27.0.2",
    "turbo": "latest",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "packageManager": "bun@1.3.9",
  "engines": {
    "bun": ">=1.0.0"
  },
  "overrides": {
    "glob": "^10.4.5",
    "rimraf": "^5.0.5",
    "lodash": "^4.17.21",
    "fast-xml-parser": "^5.3.4",
    "tmp": "^0.2.4",
    "esbuild": "^0.25.0",
    "webpack": "^5.94.0",
    "micromatch": "^4.0.8",
    "@types/express": "^4.17.21",
    "express": "^4.22.1",
    "js-yaml": "^4.1.1",
    "drizzle-orm": "^0.45.1",
    "ajv": "^8.18.0",
    "minimatch": "^10.2.1"
  },
  "dependencies": {
    "@nestjs/swagger": "^7.4.2",
    "ajv": "^8.18.0",
    "js-yaml": "^4.1.1",
    "minimatch": "^10.2.1",
    "swagger-ui-express": "^5.0.1"
  }
}