{
  "name": "apex-v2",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "ci": "biome ci .",
    "test": "turbo run test --parallel",
    "test:coverage": "turbo run test:coverage --parallel -- --coverage-reporter=lcov",
    "test:prod": "cross-env NODE_ENV=production turbo run test --parallel",
    "typecheck": "turbo run typecheck",
    "audit": "bun audit",
    "cli": "cd apps/api && bun run cli",
    "validate:env": "bun run packages/config/src/index.ts",
    "db:push": "echo 'No migrations to push'",
    "postinstall": "echo 'Run: bun install'",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@rollup/rollup-win32-x64-msvc": "4.60.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "5.0.6",
    "@types/node": "25.5.0",
    "@types/pg": "8.20.0",
    "@types/supertest": "7.2.0",
    "bcrypt": "^6.0.0",
    "bun-types": "1.3.11",
    "cross-env": "10.1.0",
    "dependency-cruiser": "17.3.10",
    "drizzle-orm": "0.45.2",
    "express": "5.2.1",
    "husky": "9.1.7",
    "jsdom": "29.0.1",
    "pg": "8.20.0",
    "redis": "5.11.0",
    "reflect-metadata": "0.2.2",
    "supertest": "7.2.2",
    "ts-morph": "27.0.2",
    "turbo": "2.9.3",
    "vite-tsconfig-paths": "6.1.1"
  },
  "packageManager": "bun@1.3.9",
  "engines": {
    "bun": ">=1.0.0"
  },
  "overrides": {
    "glob": "^10.4.5",
    "rimraf": "^5.0.5",
    "lodash": "^4.17.21",
    "fast-xml-parser": "5.5.9",
    "serialize-javascript": "^7.0.3",
    "tmp": "^0.2.4",
    "esbuild": "^0.25.0",
    "webpack": "^5.94.0",
    "micromatch": "^4.0.8",
    "@types/express": "^4.17.21",
    "express": "^4.22.1",
    "js-yaml": "^4.1.1",
    "drizzle-orm": "0.45.2",
    "pg": "8.20.0",
    "@types/pg": "8.20.0",
    "ajv": "^8.18.0",
    "minimatch": "^10.2.1",
    "qs": "6.15.0",
    "multer": "1.4.5-lts.2",
    "rollup": "4.59.0",
    "dompurify": "3.3.3",
    "file-type": "^22.0.0",
    "undici": "^7.24.2"
  },
  "dependencies": {
    "ajv": "8.18.0",
    "ajv-formats": "3.0.1",
    "dompurify": "^3.3.3",
    "fast-xml-parser": "5.5.9",
    "file-type": "^22.0.0",
    "jose": "^6.2.1",
    "js-yaml": "4.1.1",
    "jsonwebtoken": "^9.0.3",
    "minimatch": "10.2.5",
    "rollup": "^4.59.0",
    "serialize-javascript": "^7.0.4",
    "undici": "^7.24.2"
  }
}
