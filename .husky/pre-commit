#!/usr/bin/env sh

# ═══════════════════════════════════════════════════════════════
# 🛡️ APEX Security Shield - Pre-Commit Gatekeeper
# Enforces S1, S3, S9, S10, S13 before any commit
# All builds happen LOCALLY — server handles Docker only
# ═══════════════════════════════════════════════════════════════

echo "🛡️  Apex Security Shield: Initiating Pre-Commit Checks..."

# ─── S9: Supply Chain Audit ───
echo "🔍 Running S9 Audit (bun audit)..."
bun audit
if [ $? -ne 0 ]; then
  echo "❌ S9 FAILED: Vulnerability detected. Fix before committing."
  exit 1
fi
echo "✅ S9 Passed"

# ─── S10: Secret Detection ───
echo "🔍 Running S10 Scan (Secret Detection)..."
bun run scripts/security-check.ts
if [ $? -ne 0 ]; then
  echo "❌ S10 FAILED: Secret/security violation detected."
  exit 1
fi
echo "✅ S10 Passed"

# ─── S3/S13: Lint ───
echo "🔍 Running Linter..."
bun run lint
if [ $? -ne 0 ]; then
  echo "❌ Lint FAILED: Fix formatting/style issues."
  exit 1
fi
echo "✅ Lint Passed"

# ─── Local Build ───
echo "🔍 Running Build (local only)..."
bun run build
if [ $? -ne 0 ]; then
  echo "❌ Build FAILED: Fix compilation errors."
  exit 1
fi
echo "✅ Build Passed"

echo "🎉 All checks passed. Commit allowed."
