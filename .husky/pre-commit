#!/usr/bin/env bash
set -euo pipefail

# ═══════════════════════════════════════════════════════════════
# 🛡️ APEX SECURITY SHIELD v3.0 - Full S1-S15 Compliance
# Pre-Commit Gatekeeper with All 15 Security Protocols
# ═══════════════════════════════════════════════════════════════

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; NC='\033[0m'

FAILED=0; TOTAL=0; WARNINGS=0

pass() { echo -e "${GREEN}✅ S$1: $2${NC}"; TOTAL=$((TOTAL + 1)); }
fail() { echo -e "${RED}❌ S$1 FAILED: $2${NC}"; FAILED=1; TOTAL=$((TOTAL + 1)); }
warn() { echo -e "${YELLOW}⚠️  S$1: $2${NC}"; WARNINGS=$((WARNINGS + 1)); }
info() { echo -e "${BLUE}🔍 S$1: $2${NC}"; }

echo -e "${CYAN}"
cat << 'EOF'
╔════════════════════════════════════════════════════════════════╗
║           🛡️  APEX SECURITY SHIELD v3.0                        ║
║     Full S1-S15 Compliance | Zero-Trust Pre-Commit Gate       ║
╚════════════════════════════════════════════════════════════════╝
EOF
echo -e "${NC}"

# ─────────────────────────────────────────────────────────────
# S1: Environment Variables Validation
# ─────────────────────────────────────────────────────────────
info "1" "Environment Variables Validation..."

REQUIRED_ENVS=(
  "DATABASE_URL"
  "JWT_SECRET"
  "ENCRYPTION_MASTER_KEY"
)

MISSING_ENVS=""
for env in "${REQUIRED_ENVS[@]}"; do
  # Check in environment or current .env
  if [ -z "${!env:-}" ] && ! grep -q "^$env=" .env 2>/dev/null; then
    MISSING_ENVS+="   - $env\n"
  fi
done

if [ -n "$MISSING_ENVS" ]; then
  fail "1" "Missing required environment variables:\n$MISSING_ENVS"
  echo "   Create .env file or export variables"
  exit 1
fi

# Validate JWT_SECRET entropy (min 32 chars)
if [ -f ".env" ]; then
  JWT_SECRET_VAL=$(grep "^JWT_SECRET=" .env | cut -d'=' -f2 | tr -d '"' | tr -d "'" || echo "") # gitleaks:allow
  if [ ${#JWT_SECRET_VAL} -lt 32 ]; then
    fail "1" "JWT_SECRET must be at least 32 characters for security compliance"
    exit 1
  fi
fi
pass "1" "Environment variables validated"

# ─────────────────────────────────────────────────────────────
# S2: Tenant Isolation Schema Check
# ─────────────────────────────────────────────────────────────
info "2" "Tenant Isolation Schema Verification..."

if [ -d "apps/api" ]; then
  # Check for tenant schema pattern usage in middleware/service
  if ! grep -r "tenant_" apps/api/ packages/middleware/ --include="*.ts" > /dev/null 2>&1; then
    warn "2" "Tenant schema pattern not detected in core application"
  fi
fi
pass "2" "Tenant isolation patterns verified"

# ─────────────────────────────────────────────────────────────
# S3: Input Validation (TypeScript + Zod)
# ─────────────────────────────────────────────────────────────
info "3" "Input Validation & Type Safety..."

# Check for Zod usage
if ! grep -r "zod\|Zod" apps/ packages/ --include="*.ts" > /dev/null 2>&1; then
  warn "3" "Zod validation not detected in codebase"
fi
pass "3" "Type safety & validation verified"

# ─────────────────────────────────────────────────────────────
# S4: Audit Logging Verification
# ─────────────────────────────────────────────────────────────
info "4" "Audit Logging Infrastructure..."

if ! grep -r "AuditService\|audit_logs" apps/ packages/audit/ --include="*.ts" > /dev/null 2>&1; then
  fail "4" "Audit logging infrastructure missing or not implemented"
  exit 1
fi
pass "4" "Audit logging infrastructure present"

# ─────────────────────────────────────────────────────────────
# S5: Error Filtering & Sanitization
# ─────────────────────────────────────────────────────────────
info "5" "Error Filtering & Exception Handling..."

if ! grep -r "GlobalExceptionFilter" apps/api/ packages/middleware/ --include="*.ts" > /dev/null 2>&1; then
  warn "5" "Global exception filter not detected"
fi
pass "5" "Error filtering configured"

# ─────────────────────────────────────────────────────────────
# S6: Rate Limiting Configuration
# ─────────────────────────────────────────────────────────────
info "6" "Rate Limiting (Throttler) Check..."

if ! grep -r "RateLimitModule\|Throttler" apps/api/ packages/middleware/ --include="*.ts" > /dev/null 2>&1; then
  fail "6" "Rate limiting not configured in application"
  exit 1
fi
pass "6" "Rate limiting configured"

# ─────────────────────────────────────────────────────────────
# S7: Encryption Verification
# ─────────────────────────────────────────────────────────────
info "7" "Encryption & Cryptography Check..."

if ! grep -r "AES\|EncryptionService" packages/security/ --include="*.ts" > /dev/null 2>&1; then
  warn "7" "Encryption service not detected in security package"
fi

# Verify no plaintext secrets in staged code
info "7" "Scanning for plaintext secrets in staged files..."
STAGED_SEC=$(git diff --cached | grep -E "password|secret|key\s*[=:]\s*['\"][^'\"]{8,}['\"]" | grep -v "test\|spec" || true)
if [ -n "$STAGED_SEC" ]; then
  warn "7" "Potential plaintext secrets detected in staged diff"
fi
pass "7" "Encryption standards verified"

# ─────────────────────────────────────────────────────────────
# S8: Web Security (Helmet & Headers)
# ─────────────────────────────────────────────────────────────
info "8" "Web Security Headers (Helmet)..."

if ! grep -r "helmet" apps/api/src/main.ts > /dev/null 2>&1; then
  fail "8" "Helmet middleware not configured in main.ts"
  exit 1
fi
pass "8" "Helmet security headers configured"

# ─────────────────────────────────────────────────────────────
# S9: Supply Chain Security
# ─────────────────────────────────────────────────────────────
info "9" "Supply Chain Audit (S9)..."

# S9 Compliance: Block on HIGH/CRITICAL, warn on others
AUDIT_JSON=$(bun audit --json 2>/dev/null || true)
if echo "$AUDIT_JSON" | grep -q '"severity":"high"\|"severity":"critical"'; then
  fail "9" "HIGH or CRITICAL vulnerabilities found in supply chain"
  echo "$AUDIT_JSON" | grep -E '"title"|"severity"|"url"' | head -n 20
  exit 1
fi
pass "9" "Supply chain verified (No high/critical vulnerabilities)"

# ─────────────────────────────────────────────────────────────
# S10: Secret Detection (Enhanced)
# ─────────────────────────────────────────────────────────────
info "10" "Secret Detection (Surgical Pattern Scan)..."

# Robust regex-based scan for secrets in staged files (S10 Compliance)
SECRET_FOUND=$(git diff --cached | grep -E "(JWT_SECRET|ENCRYPTION_MASTER_KEY|password|passwd|pwd|secret|token|api_key|apikey)\s*[=:]\s*['\"][^'\"]{8,}['\"]" | grep -v "test\|spec\|gitleaks:allow\|security:allow" || true)
if [ -n "$SECRET_FOUND" ]; then
  fail "10" "SECRETS DETECTED: Remove secrets or use 'gitleaks:allow' comment."
  echo "$SECRET_FOUND"
  exit 1
fi
pass "10" "No secrets detected"

# ─────────────────────────────────────────────────────────────
# S11: Bot Protection
# ─────────────────────────────────────────────────────────────
info "11" "Bot Protection Middleware..."

if ! grep -r "BotProtection" apps/api/ packages/middleware/ --include="*.ts" > /dev/null 2>&1; then
  fail "11" "Bot protection middleware not found"
  exit 1
fi
pass "11" "Bot protection configured"

# ─────────────────────────────────────────────────────────────
# S12: DDoS Protection
# ─────────────────────────────────────────────────────────────
info "12" "DDoS Protection Verification..."
if ! grep -r "ratelimit" ops/docker-compose.prod.yml > /dev/null 2>&1; then
  warn "12" "Traefik rate limits not found in production compose"
fi
pass "12" "DDoS protection verified"

# ─────────────────────────────────────────────────────────────
# S13: Security Testing (CI Check)
# ─────────────────────────────────────────────────────────────
info "13" "Security Testing Configuration..."
if [ ! -f ".github/workflows/ci-main.yml" ]; then
  warn "13" "CI workflow not found for security scanning"
else
  if ! grep -q "snyk\|zap" .github/workflows/ci-main.yml; then
    warn "13" "Security scans (Snyk/ZAP) not found in CI workflow"
  fi
fi
pass "13" "Security testing checked"

# ─────────────────────────────────────────────────────────────
# S14: Fraud Detection
# ─────────────────────────────────────────────────────────────
info "14" "Fraud Detection Mechanisms..."
if ! grep -r "FraudGuard\|FraudScoring" apps/api/ packages/middleware/ --include="*.ts" > /dev/null 2>&1; then
  warn "14" "Fraud detection guards not detected"
fi
pass "14" "Fraud detection checked"

# ─────────────────────────────────────────────────────────────
# S15: Active Defense (Honeytokens)
# ─────────────────────────────────────────────────────────────
info "15" "Active Defense (Honeytokens)..."
if ! grep -r "HoneyTokensController" apps/api/ --include="*.ts" > /dev/null 2>&1; then
  fail "15" "Honeytokens controller missing or not registered"
  exit 1
fi
pass "15" "Active defense checked"

# ─────────────────────────────────────────────────────────────
# S21: Build Integrity (Final Quality Gate)
# ─────────────────────────────────────────────────────────────
#info "21" "Build Integrity & Compilation Check..."

# In a monorepo, a full build is expensive but ensures zero-regression
# if ! bun run build --filter=@apex/api ; then
#  fail "21" "Build failed. Fix compilation errors before committing."
#  exit 1
# fi
# pass "21" "Build integrity verified" 

# ─────────────────────────────────────────────────────────────
# Final Report
# ─────────────────────────────────────────────────────────────
echo ""
echo -e "${BLUE}════════════════════════════════════════════════════════════════${NC}"

if [ $FAILED -eq 0 ]; then
  echo -e "${GREEN}🛡️  ALL S1-S15 PROTOCOLS PASSED | GATE AUTHORIZED ✅${NC}"
  [ $WARNINGS -gt 0 ] && echo -e "${YELLOW}⚠️  $WARNINGS security warnings remained (non-blocking)${NC}"
  exit 0
else
  echo -e "${RED}🚫 SECURITY PROTOCOLS VIOLATED | GATE CLOSED ❌${NC}"
  exit 1
fi
