{
  "glossary": {
    "title": "Apex v2 Master Specification: Grocery/Supermarket Edition",
    "version": "2.1.0",
    "target_benchmark": ["Amazon Fresh", "Jumia Food", "Carrefour Online"],
    "total_sections": 55
  },
  "technical_specifications": {
    "01_core_stack": {
      "framework": "Next.js 14 (App Router)",
      "language": "TypeScript 5.3+ (Strict Mode)",
      "runtime": "Bun (Performance Optimized)",
      "styling": "TailwindCSS + Shadcn/UI + PostCSS"
    },
    "02_security_protocols": {
      "s1_input_validation": "Zod double-gate validation (Client + Server)",
      "s2_sql_injection": "Drizzle ORM strict type-casting",
      "s3_xss_protection": "React strict escaping + DOMPurify for user content",
      "s4_csrf_protection": "SameSite cookies + CSRF tokens for mutations",
      "s5_rate_limiting": "Redis-based fixed window counters per IP/Tenant",
      "s6_authentication": "JWT (Stateless) + Refresh Tokens + RBAC",
      "s7_encryption": "AES-256 for data-at-rest, TLS 1.3 for transit",
      "s8_audit_logging": "Immutable audit trails for all sensitive actions"
    },
    "03_performance_metrics": {
      "lcp_target": "< 2.5s (Largest Contentful Paint)",
      "fid_target": "< 100ms (First Input Delay)",
      "cls_target": "< 0.1 (Cumulative Layout Shift)",
      "caching_strategy": "Stale-While-Revalidate (SWR) for dynamic data"
    },
    "04_infrastructure": {
      "database": "PostgreSQL 16 + pgvector (AI Search)",
      "cache": "Redis 7.x (Sessions, Rate Limits, Caching)",
      "search_engine": "Hybrid (Keyword + Semantic Vector Search)",
      "cdn": "Global Edge Network for static assets"
    }
  },
  "frontend_standards": {
    "05_ui_ux_philosophy": {
      "design_system": "Atomic Design (Atoms -> Molecules -> Organisms)",
      "theme": "Glassmorphism + Neomorphism accents",
      "animations": "Framer Motion (60fps micro-interactions)",
      "accessibility": "WCAG 2.1 AA Compliant (Screen readers, Keyboard nav)"
    },
    "06_responsive_behavior": {
      "mobile_first": "Touch-optimized hit targets (>44px)",
      "breakpoints": {
        "sm": "640px (Mobile)",
        "md": "768px (Tablet)",
        "lg": "1024px (Desktop)",
        "xl": "1280px (Wide)"
      }
    },
    "07_localization": {
      "i18n_support": "Native RTL/LTR switching (Arabic/English)",
      "currency_formatting": "Locale-aware (e.g., EGP 1,234.50 vs $1,234.50)",
      "number_formatting": "Eastern/Western Arabic numerals support"
    }
  },
