# ═══════════════════════════════════════════════════════════════
# APEX Monorepo .gitignore (NestJS + Bun + Turbo)
# S10 Compliance: Prevent sensitive file leaks
# ═══════════════════════════════════════════════════════════════

# ─── Dependencies ───
node_modules/
**/node_modules/

# ─── Build Outputs ───
dist/
**/dist/
.next/
out/
build/
*.tsbuildinfo

# ─── TSC Build Artifacts in Source Dirs ───
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map

# ─── Coverage ───
coverage/
**/coverage/
.nyc_output/

# ─── Turbo ───
.turbo/

# ─── Environment Variables (S10 Critical) ───
.env
.env.*
!.env.example
!.env.production.example

# ─── Logs ───
*.log
npm-debug.log*
yarn-debug.log*
lerna-debug.log*
.pnpm-debug.log*

# ─── SSH Keys & Secrets (S10 Critical) ───
ops/keys/
*.pem
*.key
id_rsa*
id_ed25519*
secrets.json
credentials.json

# ─── IDE ───
.idea/
.vscode/
*.swp
*.swo
*~

# ─── OS ───
.DS_Store
Thumbs.db

# ─── Docker Volumes ───
postgres_data/
redis_data/
minio_data/
mailpit_data/
letsencrypt_data/
gitea_data/

# ─── Temporary Files ───
*.tmp
*.temp

# ─── Agent & Security Vaults ───
.agent/
.gemini/
brain/
*masterlist.md

# ─── Codebase Exports (potential secrets) ───
update/
Apex_2026_*.txt
Collect-Project.ps1

# ─── Embedded repos ───
KIMI/
